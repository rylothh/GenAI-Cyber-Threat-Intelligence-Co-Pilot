# --- CORE API WRAPPER & HELPER FUNCTIONS ---
function Clean-Input {
    param([string]$Text)
    if ([string]::IsNullOrWhiteSpace($Text)) { return "" }
    $Text = $Text.Trim()
    # Safely strip outer quotes ONLY if they surround the entire string.
    if ($Text -match '^"(.*)"$') { $Text = $Matches[1] }
    elseif ($Text -match "^'(.*)'$") { $Text = $Matches[1] }
    return $Text.Trim()
}

function Invoke-SafeRest {
    param($Uri, $Headers, $Method = 'Get', $Body)
    try {
        $SafeAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) PowerShell/CTI-CoPilot"
        $params = @{ Uri = $Uri; Method = $Method; TimeoutSec = 25; UserAgent = $SafeAgent }
        if ($Headers) { $params.Headers = $Headers }
        if ($Body) { $params.Body = $Body }
        return Invoke-RestMethod @params
    } catch { return $null }
}

function Get-BdeInfo {
    param([string]$SearchLocation)
    $Result = @{ Location = $SearchLocation; BDE = "(Check manual list)"; MACOM = "(Check manual list)" }
    if ([string]::IsNullOrWhiteSpace($SearchLocation) -or $SearchLocation -eq "N/A") { 
        $Result.Location = "(Check https://www.nic.mil/cgi-bin/whoisweb)"
        return $Result 
    }
    foreach ($Row in $Global:BdeMasterList) {
        if ($Row.Location -match [regex]::Escape($SearchLocation) -or $SearchLocation -match [regex]::Escape($Row.Location)) {
            $Result.Location = $Row.Location 
            $Result.BDE = $Row.BDE
            $Result.MACOM = $Row.MACOM
            break
        }
    }
    return $Result
}

function Get-NsLookup {
    param($Target)
    if ([string]::IsNullOrWhiteSpace($Target) -or $Target -eq "N/A") { return "N/A" }
    
    $NsRaw = cmd.exe /c "nslookup $Target 2>&1" | Out-String
    if ($NsRaw -match "Non-existent domain|can't find|NXDOMAIN|\*\*\*") {
        return "Non-existent domain"
    } elseif ([string]::IsNullOrWhiteSpace($NsRaw)) {
        return "Non-existent domain"
    } elseif ($NsRaw -match "(?im)^Name:\s+(.+)") {
        return $Matches[1].Trim()
    } else {
        return $NsRaw.Trim()
    }
}

function Test-IsPrivateIP {
    param([string]$IP)
    if ([string]::IsNullOrWhiteSpace($IP)) { return $false }
    if ($IP -match "^10\.") { return $true }
    if ($IP -match "^192\.168\.") { return $true }
    if ($IP -match "^172\.(1[6-9]|2[0-9]|3[0-1])\.") { return $true }
    return $false
}

function Test-IsDoD {
    param([string]$NetName, [string]$Descr, [string]$Owner, [string]$NsLookup)
    # Aggressively expanded Regex to catch substring variations (e.g. armystrongstories)
    $DoDRegex = "(?i)\b(DoD|DoDNIC|Department of Defense|DISA|Defense Information Systems Agency|US Army|U\.?S\.? Army|US Navy|U\.?S\.? Navy|US Air Force|U\.?S\.? Air Force|USMC|Marine Corps|Pentagon|Defense Logistics Agency|National Guard)\b|(?i)(\.mil\b|usarmy|usnavy|usaf|usmc|army|navy|airforce|marines|rotc)"
    
    if ($NetName -match $DoDRegex) { return $true }
    if ($Descr -match $DoDRegex) { return $true }
    if ($Owner -match $DoDRegex) { return $true }
    if ($NsLookup -match $DoDRegex) { return $true }
    return $false
}

function Get-ProtocolFromPort {
    param([string]$Port)
    if ([string]::IsNullOrWhiteSpace($Port) -or $Port -eq "N/A") { return "N/A" }
    switch ($Port) {
        "20"   { return "TCP (FTP Data)" }
        "21"   { return "TCP (FTP Control)" }
        "22"   { return "TCP (SSH)" }
        "23"   { return "TCP (Telnet)" }
        "25"   { return "TCP (SMTP)" }
        "53"   { return "TCP/UDP (DNS)" }
        "67"   { return "UDP (DHCP Server)" }
        "68"   { return "UDP (DHCP Client)" }
        "69"   { return "UDP (TFTP)" }
        "80"   { return "TCP (HTTP)" }
        "110"  { return "TCP (POP3)" }
        "123"  { return "UDP (NTP)" }
        "135"  { return "TCP (RPC)" }
        "137"  { return "UDP (NetBIOS Name Service)" }
        "138"  { return "UDP (NetBIOS Datagram Service)" }
        "139"  { return "TCP (NetBIOS Session Service)" }
        "143"  { return "TCP (IMAP)" }
        "161"  { return "UDP (SNMP)" }
        "162"  { return "UDP (SNMP Trap)" }
        "389"  { return "TCP/UDP (LDAP)" }
        "443"  { return "TCP (HTTPS)" }
        "445"  { return "TCP (SMB)" }
        "465"  { return "TCP (SMTPS)" }
        "500"  { return "UDP (ISAKMP/IKE)" }
        "514"  { return "UDP (Syslog)" }
        "587"  { return "TCP (SMTP Implicit TLS)" }
        "636"  { return "TCP/UDP (LDAPS)" }
        "993"  { return "TCP (IMAPS)" }
        "995"  { return "TCP (SMTP Explicit TLS)" }
        "1433" { return "TCP (MSSQL)" }
        "1521" { return "TCP (Oracle)" }
        "3306" { return "TCP (MySQL)" }
        "3389" { return "TCP (RDP)" }
        "5432" { return "TCP (PostgreSQL)" }
        "5900" { return "TCP (VNC)" }
        "8080" { return "TCP (HTTP Alternate)" }
        "8443" { return "TCP (HTTPS Alternate)" }
        default { return "N/A" }
    }
}

function Unwrap-Arin {
    param($Item)
    if ($null -eq $Item) { return "" }
    if ($null -ne $Item.'$') { return [string]$Item.'$' }
    return [string]$Item
}

# HELPER: TRIPLE-THREAT RDAP EXTRACTOR
function Get-RdapInfo {
    param($IP)
    $Result = @{ NetRange = "N/A"; NetName = "N/A"; Country = "N/A"; Descr = "N/A"; StateProv = "N/A" }
    if ([string]::IsNullOrWhiteSpace($IP) -or $IP -eq "N/A") { return $Result }
    
    Write-Host "[!] Querying Registry Data for $IP..." -ForegroundColor Cyan
    
    $ArinRest = Invoke-SafeRest -Uri "https://whois.arin.net/rest/ip/$($IP).json"
    if ($ArinRest -and $ArinRest.net) {
        $start = Unwrap-Arin $ArinRest.net.startAddress
        $end = Unwrap-Arin $ArinRest.net.endAddress
        if ($start -and $end) { $Result.NetRange = "$start - $end" }
        
        $nName = Unwrap-Arin $ArinRest.net.name
        if ($nName) { $Result.NetName = $nName }
        
        if ($ArinRest.net.orgRef.'@name') { $Result.Descr = [string]$ArinRest.net.orgRef.'@name' }
        
        $orgUrl = Unwrap-Arin $ArinRest.net.orgRef
        if ($orgUrl) {
            $ArinOrg = Invoke-SafeRest -Uri "$($orgUrl).json"
            if ($ArinOrg -and $ArinOrg.org) {
                $st = Unwrap-Arin $ArinOrg.org.'iso3166-2'
                if ($st) { $Result.StateProv = $st }
                
                $cty = Unwrap-Arin $ArinOrg.org.'iso3166-1'.code2
                if ($cty) { $Result.Country = $cty }
            }
        }
    } else {
        $RdapGlobal = Invoke-SafeRest -Uri "https://rdap.org/ip/$IP" -Headers @{ "Accept" = "application/rdap+json" }
        if ($RdapGlobal) {
            if ($RdapGlobal.startAddress -and $RdapGlobal.endAddress) { $Result.NetRange = "$($RdapGlobal.startAddress) - $($RdapGlobal.endAddress)" }
            elseif ($RdapGlobal.inetnum) { $Result.NetRange = $RdapGlobal.inetnum }
            
            if ($RdapGlobal.name) { $Result.NetName = $RdapGlobal.name }
            if ($RdapGlobal.country) { $Result.Country = $RdapGlobal.country }
            
            try { if ($RdapGlobal.remarks) { $Result.Descr = $RdapGlobal.remarks[0].description[0] } } catch {}
        }
    }
    
    if ($Result.Country -eq "N/A" -or $Result.StateProv -eq "N/A" -or $Result.Descr -eq "N/A") {
        $GeoApi = Invoke-SafeRest -Uri "https://ipapi.co/$IP/json/"
        if ($GeoApi -and (-not $GeoApi.error)) {
            if ($Result.Country -eq "N/A" -and $GeoApi.country_code) { $Result.Country = $GeoApi.country_code }
            if ($Result.StateProv -eq "N/A" -and $GeoApi.region_code) { $Result.StateProv = $GeoApi.region_code }
            if ($Result.Descr -eq "N/A" -and $GeoApi.org) { $Result.Descr = $GeoApi.org }
        }
    }
    
    foreach ($key in @('NetRange', 'NetName', 'Country', 'Descr', 'StateProv')) {
        if ([string]::IsNullOrWhiteSpace($Result[$key])) { $Result[$key] = "N/A" }
    }
    
    return $Result
}

# --- GENAI ANALYSIS ---
function Invoke-AIAnalysis {
    param($ContextData, $ElasticRule)
    Write-Host "[i] Requesting AI Intelligence Analysis..." -ForegroundColor Magenta
    $Headers = @{ "Authorization" = "Bearer $GenAI_Key"; "Content-Type" = "application/json" }
    
    $Prompt = "Expert cyber incident handling analysis. Plain text only!!! Avoid usage of unintelligible non-English ascii-style formatting where not commanded in this prompt. Do not use emojis. Do not use HTML/CSS formatting to bold/italics/list or order, etc as it will not work in plaintext. If producing a URL, file hash, or filepath from a potentially malicious payload, obfuscate or defang the URL by placing brackets around the colons, and replace 'https' with 'hxxps' by whatever means necessary to prevent it from highlighting as an embedded URL or hyperlink, to prevent accidental clicking. DO NOT defang or obfuscate IPs. When writing in the 'CSSP Analysis' section, write only your analysis; no extra formatting such as hyphens, linebreaks, etcetera are required, and no title is required as your prompt is pre-formatted to inject into a Powershell script outside of Gemini. Be detailed yet concise. Analyze the provided telemetry based on the text context appended below, which contains pre-gathered open-source intelligence. Do not attempt to run any external lookups yourself. The alert triggered on this Elastic Rule: '$ElasticRule'. 1 paragraph summary assessing the relationship between these indicators and the rule. DO NOT SAY ANYTHING ALONG THE LINES OF 'I, Gemini Enterprise, have analyzed the network telemetry involving source IP 3.5.12.238 and target IP 65.116.218.113.' Do not acknowledge yourself in your analysis. Do not write any suggestions or recommendations; write only the facts that have been observed with open source material." + $ContextData
    
    $Payload = @{ model = $GenAI_Model; messages = @(@{ role = "user"; content = $Prompt }) } | ConvertTo-Json -Depth 10
    $Response = Invoke-SafeRest -Uri $GenAI_Endpoint -Method Post -Headers $Headers -Body $Payload
    if ($Response) { return $Response.choices[0].message.content.Trim() }
    return "AI Analysis failed to generate a response. Resend another request as this may have been a parsing issue. If this occurs multiple times and is not due to network access or admin restrictions, check that the GenAI API key in this code is unlocked or active as the key may have expired. Go to https://genai.mil/stark/user-ui/ for new API keys."
}

# --- INTERACTIVE CHAT SESSION ---
function Start-AIChat {
    param($Context, $Verdict, $ElasticRule)
    Write-Host "`n--- AI CHAT MODE ACTIVATED ---" -ForegroundColor Magenta
    Write-Host "Type 'done' to exit.`n" -ForegroundColor Gray
    $History = @(); $History += @{ role = "system"; content = "Expert cyber incident handling analysis. Rule: $ElasticRule. Context: $Context. Verdict: $Verdict. You must analyze based on the provided context only, do not attempt to run external lookups." }
    while ($true) {
        $In = Clean-Input (Read-Host -Prompt "[YOU]")
        if ($In -eq 'done' -or $In -eq 'exit') { break }
        $History += @{ role = "user"; content = $In }
        $Payload = @{ model = $GenAI_Model; messages = $History } | ConvertTo-Json -Depth 10
        $Res = Invoke-SafeRest -Uri $GenAI_Endpoint -Method Post -Headers @{ "Authorization" = "Bearer $GenAI_Key"; "Content-Type" = "application/json" } -Body $Payload
        if ($Res) { $Ans = $Res.choices.message.content.Trim(); Write-Host "[AI] $Ans`n" -ForegroundColor Cyan; $History += @{ role = "assistant"; content = $Ans } }
    }
}

# --- TICKET GENERATOR ---
function Write-Ticket {
    param(
        $Type, $Indicator, $NetName, $Country, $Descr, $VT, $Abuse, $ISP, $Link, $BdeData, $AI = "", $ArinH, 
        $SrcPort = "N/A", $MilIP = "N/A", $MilPort = "N/A", $Protocol = "N/A", $SrcNsResult = "N/A", $MilNsResult = "N/A", $MilArinH = "N/A", $MilArinN = "N/A", $MilDescr = "N/A", $MilCountry = "N/A", $MilStateProv = "N/A", $MilLink = "N/A", $IsPrivateIP = $false,
        $Sensor = "N/A", $EventTime = "N/A", $PayloadData = "N/A", $IsDoD = $false
    )
    
    if ($IsDoD) {
        $DomFor = "Domestic (DoD / Military)"
    } elseif ($IsPrivateIP) {
        $DomFor = "Internal/Private (RFC 1918)"
    } elseif ($Country -eq "US") { 
        $DomFor = "Domestic" 
    } elseif ($Country -ne "N/A") { 
        $DomFor = "Foreign" 
    } else {
        $DomFor = "N/A"
    }
    
    $MilLink = "N/A"; if ($MilIP -ne "N/A") { $MilLink = "https://www.whois.com/whois/$MilIP" }
    
    $T =  "- AFFECTED LOCATION: $($BdeData.Location)`n"
    $T += "- BDE: $($BdeData.BDE)`n- MACOM: $($BdeData.MACOM)`n- COCOM: NORTHCOM`n- EVENT TIME: $EventTime`n- SENSOR: $Sensor`n- PROTOCOL: $Protocol`n"
    $T += "************************************************************`n"
    $T += "PAYLOAD: $PayloadData`n"
    $T += "************************************************************`n"
    $T += "Source IP Foreign or Domestic: $DomFor`n`n"
    $T += "- Source IP: $Indicator ($Type)`n- Source Port: $SrcPort`n- NSLOOKUP: $SrcNsResult`n`n"
    
    $T += "--- SOURCE ARIN ---`n"
    $T += "NetRange:    $ArinH`nNetName:    $NetName`nDescr:    $Descr`nCountry:    $Country`n"
    $T += "WHOIS LINK: $Link`n`n"
    
    $T += "- THREAT INTEL:`n"
    $T += "VirusTotal: $VT`nAbuseIPDB Score: $Abuse`nAbuseIPDB ISP:  $ISP`n"
    $T += "************************************************************`n"
    $T += "MIL IP Foreign or domestic: Domestic`n`n"
    $T += "MIL Destination`n- Destination IP: $MilIP`n- Destination Port: $MilPort`n- NSLOOKUP: $MilNsResult`n`n"
    
    $T += "--- DESTINATION (MIL) ARIN ---`n"
    $T += "NetRange:    $MilArinH`nNetName:    $MilArinN`nDescr:    $MilDescr`nCountry:    $MilCountry`nState/Prov:    $MilStateProv`n"
    $T += "WHOIS LINK: $MilLink`n"
    
    # Only include MDE block if the input is NOT an IP
    if ($Type -ne "IP") {
        $T += "************************************************************`n"
        $T += "- MDE:`n"
    }
    
    $T += "************************************************************`n"
    
    # CSSP Action Logic
    if ($Type -eq "IP" -and $IsDoD) {
        $T += "- CSSP ANALYSIS:`n`n$AI`n`n[WARNING: Source IP belongs to the Department of Defense (DoD). IP blocking is NOT recommended without explicit authorization.]"
    } elseif ($Type -eq "IP" -and $IsPrivateIP) {
        $T += "- CSSP ANALYSIS:`n`n$AI`n`n[WARNING: Source IP is an internal/private address. External IP blocking is not applicable.]"
    } else {
        $T += "- CSSP ANALYSIS:`n`n$AI`n`nDespite the action being blocked by an IPS, there are currently no IP-Blocks submitted at the network / IP level. CSSP is submitting a 30-day IP-Block request as an additional countermeasure."
    }

    # 1. Send plain text to clipboard
    $T | Set-Clipboard
    
    # 2. Print to console with N/A highlighted in Red
    $T_Lines = $T -split "`n"
    foreach ($Line in $T_Lines) {
        if ($Line -match "N/A") {
            $Parts = $Line -split "N/A"
            for ($i = 0; $i -lt $Parts.Count; $i++) {
                Write-Host $Parts[$i] -NoNewline -ForegroundColor Green
                if ($i -lt ($Parts.Count - 1)) { Write-Host "N/A" -NoNewline -ForegroundColor Red }
            }
            Write-Host ""
        } else {
            Write-Host $Line -ForegroundColor Green
        }
    }
    Write-Host "`n[SUCCESS] Exact Layout Ticket copied to clipboard." -ForegroundColor Cyan
}

# --- MAIN LOOP ---
while ($true) {
    Write-Host "`n==================================================" -ForegroundColor Red
    Write-Host "   CYBER THREAT INTELLIGENCE CO-PILOT v8.18.0" -ForegroundColor Blue
    Write-Host "==================================================" -ForegroundColor Red
    $In = Clean-Input (Read-Host -Prompt "`nEnter Indicator (Source IP, URL, Hash) or 'Exit'")
    if ($In -eq 'Exit' -or $In -eq 'exit') { break }
    
    if ($In -match "^(\d{1,3}\.){3}\d{1,3}$") { 
        # IP ROUTE
        Write-Host "[!] Analyzing IP: $In..." -ForegroundColor Cyan
        
        $IsPrivate = Test-IsPrivateIP -IP $In
        if ($IsPrivate) { 
            Write-Host "`n************************************************************" -ForegroundColor Red -BackgroundColor Black
            Write-Host " [CRITICAL WARNING] INTERNAL/PRIVATE IP DETECTED (RFC 1918) " -ForegroundColor White -BackgroundColor Red
            Write-Host " DO NOT BLOCK THIS IP. PLEASE DOUBLE-CHECK YOUR INDICATOR!  " -ForegroundColor White -BackgroundColor Red
            Write-Host "************************************************************`n" -ForegroundColor Red -BackgroundColor Black
        }
        
        # 1. State Machine for Inputs with Step-Back feature
        $step = 1
        while ($step -le 8) {
            switch ($step) {
                1 { 
                    $SrcPort = Clean-Input (Read-Host -Prompt "1/8: Enter Source Port (or 'b' to go back, Enter to skip)")
                    if ($SrcPort -eq 'b') { Write-Host "[!] Already at first step." -ForegroundColor Yellow; continue }
                    $step++
                }
                2 {
                    $MilIP = Clean-Input (Read-Host -Prompt "2/8: Enter MIL Dest IP (or 'b' to go back, Enter to skip)")
                    if ($MilIP -eq 'b') { $step--; continue }
                    $step++
                }
                3 {
                    $MilPort = Clean-Input (Read-Host -Prompt "3/8: Enter MIL Dest Port (or 'b' to go back, Enter to skip)")
                    if ($MilPort -eq 'b') { $step--; continue }
                    $step++
                }
                4 {
                    $ElasticRule = Clean-Input (Read-Host -Prompt "4/8: Enter Elastic observer.rule.name (or 'b' to go back, Enter to skip)")
                    if ($ElasticRule -eq 'b') { $step--; continue }
                    $step++
                }
                5 {
                    $InputLocation = Clean-Input (Read-Host -Prompt "5/8: Enter Affected Location/Base (e.g. 'Liberty') (or 'b' to go back)")
                    if ($InputLocation -eq 'b') { $step--; continue }
                    $step++
                }
                6 {
                    $Sensor = Clean-Input (Read-Host -Prompt "6/8: Enter Elastic observer.name / SENSOR (or 'b' to go back, Enter to skip)")
                    if ($Sensor -eq 'b') { $step--; continue }
                    $step++
                }
                7 {
                    $EventTime = Clean-Input (Read-Host -Prompt "7/8: Enter Elastic @attack_time / EVENT TIME (or 'b' to go back, Enter to skip)")
                    if ($EventTime -eq 'b') { $step--; continue }
                    $step++
                }
                8 {
                    $PayloadData = Clean-Input (Read-Host -Prompt "8/8: Enter Elastic http.request.body.content / PAYLOAD (or 'b' to go back, Enter to skip)")
                    if ($PayloadData -eq 'b') { $step--; continue }
                    $step++
                }
            }
        }
        
        # Normalize gathered variables
        if ([string]::IsNullOrWhiteSpace($SrcPort)) { $SrcPort = "N/A" }
        if ([string]::IsNullOrWhiteSpace($MilPort)) { $MilPort = "N/A" }
        if ([string]::IsNullOrWhiteSpace($ElasticRule)) { $ElasticRule = "None Provided" }
        if ([string]::IsNullOrWhiteSpace($Sensor)) { $Sensor = "N/A" }
        if ([string]::IsNullOrWhiteSpace($EventTime)) { $EventTime = "N/A" }
        if ([string]::IsNullOrWhiteSpace($PayloadData)) { $PayloadData = "N/A" }
        
        # Infer Protocol
        $InferredProtocol = Get-ProtocolFromPort -Port $MilPort
        
        # Pull NSLookup Early for Source DoD Verification
        $SrcNsResult = Get-NsLookup -Target $In
        
        # 2. Open Source Intelligence Lookups
        $AbRes = Invoke-SafeRest -Uri "https://api.abuseipdb.com/api/v2/check?ipAddress=$In&maxAgeInDays=90" -Headers @{ "Key" = $Abuse_Key; "Accept" = "application/json" }
        $Ab = "N/A"; $ISP = "N/A"; $Cty = "N/A"
        if ($AbRes) { $Ab = "$($AbRes.data.abuseConfidenceScore)%"; $ISP = $AbRes.data.isp; $Cty = $AbRes.data.countryCode }
        
        $Vt = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/ip_addresses/$In" -Headers @{ "x-apikey" = $VT_Key }
        $VTRes = "API Error"; $Owner = "N/A"
        if ($Vt) { $VTRes = "$($Vt.data.attributes.last_analysis_stats.malicious) Detections"; $Owner = $Vt.data.attributes.as_owner }
        
        # 3. Pull BDE/RDAP data
        $BdeData = Get-BdeInfo -SearchLocation $InputLocation
        $SrcArin = Get-RdapInfo -IP $In
        
        # Check for DoD Status
        $IsDoDStatus = Test-IsDoD -NetName $SrcArin.NetName -Descr $SrcArin.Descr -Owner $Owner -NsLookup $SrcNsResult
        if ($IsDoDStatus) { 
            Write-Host "`n************************************************************" -ForegroundColor Red -BackgroundColor Black
            Write-Host " [CRITICAL WARNING] DoD / MILITARY SOURCE IP DETECTED       " -ForegroundColor White -BackgroundColor Red
            Write-Host " DO NOT BLOCK THIS IP WITHOUT EXPLICIT AUTHORIZATION!       " -ForegroundColor White -BackgroundColor Red
            Write-Host "************************************************************`n" -ForegroundColor Red -BackgroundColor Black
        }
        
        $MilNsResult = "N/A"; $MilLink = "N/A"
        $MilArin = @{ NetRange = "N/A"; NetName = "N/A"; Country = "N/A"; Descr = "N/A"; StateProv = "N/A" }
        if ($MilIP -match "^(\d{1,3}\.){3}\d{1,3}$") {
            $MilNsResult = Get-NsLookup -Target $MilIP
            $MilArin = Get-RdapInfo -IP $MilIP
            $MilLink = "https://www.whois.com/whois/$MilIP"
        }
        
        $Net = $ISP; if ($Owner -ne "N/A") { $Net = $Owner }
        $Ctx = "IP:$In, Net:$Net, Abuse:$Ab, VT:$VTRes"
        if ($MilIP -ne "") { $Ctx += ", TargetIP:$MilIP" }
        
        # 4. AI Generation & Re-Run Loop
        $AnalyzeLoop = $true
        do {
            $AI = Invoke-AIAnalysis -ContextData $Ctx -ElasticRule $ElasticRule
            
            Write-Ticket -Type "IP" -Indicator $In -NetName $SrcArin.NetName -Country $SrcArin.Country -Descr $SrcArin.Descr `
                         -VT $VTRes -Abuse $Ab -ISP $ISP -Link "https://www.whois.com/whois/$In" -AI $AI -ArinH $SrcArin.NetRange `
                         -SrcPort $SrcPort -MilIP $MilIP -MilPort $MilPort -Protocol $InferredProtocol -SrcNsResult $SrcNsResult -MilNsResult $MilNsResult -MilArinH $MilArin.NetRange `
                         -MilArinN $MilArin.NetName -MilDescr $MilArin.Descr -MilCountry $MilArin.Country -MilStateProv $MilArin.StateProv `
                         -MilLink $MilLink -BdeData $BdeData -IsPrivateIP $IsPrivate -IsDoD $IsDoDStatus `
                         -Sensor $Sensor -EventTime $EventTime -PayloadData $PayloadData
                         
            Write-Host "`n[?] Post-Ticket Actions:" -ForegroundColor Yellow
            Write-Host "[r] Re-run AI Analysis (e.g., if API key was locked)"
            Write-Host "[c] Start Interactive AI Chat"
            Write-Host "[Enter] Analyze a new indicator"
            $PostAction = Read-Host -Prompt "Action"
            
            if ($PostAction -eq 'r') {
                Write-Host "`n[!] Re-running analysis with existing data..." -ForegroundColor Cyan
            } elseif ($PostAction -eq 'c') {
                Start-AIChat -Context $Ctx -Verdict $AI -ElasticRule $ElasticRule
                $AnalyzeLoop = $false
            } else {
                $AnalyzeLoop = $false
            }
        } while ($AnalyzeLoop -eq $true)
    }
    elseif ($In -like "*.*" -and $In -notmatch "^([a-fA-F0-9]{64}|[a-fA-F0-9]{32})$") {
        # URL ROUTE
        $Domain = $In.Replace("https://","").Replace("http://","").Split("/")[0]
        Write-Host "[!] Analyzing URL/Domain: $In..." -ForegroundColor Cyan
        
        $BdeDataBlank = @{ Location = "N/A"; BDE = "N/A"; MACOM = "N/A" }
        $ElasticRule = "None Provided"
        $SrcNsResult = Get-NsLookup -Target $Domain
        
        $UsReq = Invoke-SafeRest -Uri "https://urlscan.io/api/v1/scan/" -Method Post -Headers @{ 'API-Key' = $UrlScan_Key; 'Content-Type' = 'application/json' } -Body (@{ url = $In; visibility = "public" } | ConvertTo-Json)
        $UsVal = "Wait for Report"
        if ($UsReq) { Start-Sleep -Seconds 20; $UsRes = Invoke-SafeRest -Uri "https://urlscan.io/api/v1/result/$($UsReq.uuid)/"; if ($UsRes) { $UsVal = "Clean"; if ($UsRes.verdicts.overall.malicious) { $UsVal = "Malicious" } } }
        
        $Vt = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/urls" -Method Post -Headers @{ "x-apikey" = $VT_Key } -Body (@{ url = $In } | ConvertTo-Json)
        $VTRes = "API Error"
        if ($Vt) { Start-Sleep -Seconds 15; $VtR = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/urls/$($Vt.data.id.Split('-')[1])" -Headers @{ "x-apikey" = $VT_Key }; if ($VtR) { $VTRes = "$($VtR.data.attributes.last_analysis_stats.malicious) Detections" } }
        
        $Ctx = "URL:$In, Domain:$Domain, URLScan:$UsVal, VT:$VTRes"
        
        $AnalyzeLoop = $true
        do {
            $AI = Invoke-AIAnalysis -ContextData $Ctx -ElasticRule $ElasticRule
            Write-Ticket -Type "URL" -Indicator $In -NetName $Domain -Country "N/A" -Descr "N/A" -VT $VTRes -Abuse $UsVal -ISP "URLScan" -Link "https://www.whois.com/whois/$Domain" -AI $AI -ArinH "N/A" -BdeData $BdeDataBlank -Protocol "N/A" -SrcNsResult $SrcNsResult
            
            Write-Host "`n[?] Post-Ticket Actions:" -ForegroundColor Yellow
            Write-Host "[r] Re-run AI Analysis"
            Write-Host "[c] Start Interactive AI Chat"
            Write-Host "[Enter] Analyze a new indicator"
            $PostAction = Read-Host -Prompt "Action"
            
            if ($PostAction -eq 'r') { Write-Host "`n[!] Re-running..." -ForegroundColor Cyan }
            elseif ($PostAction -eq 'c') { Start-AIChat -Context $Ctx -Verdict $AI -ElasticRule $ElasticRule; $AnalyzeLoop = $false }
            else { $AnalyzeLoop = $false }
        } while ($AnalyzeLoop -eq $true)
    }
    elseif ($In -match "^([a-fA-F0-9]{64}|[a-fA-F0-9]{32})$") {
        # HASH ROUTE
        Write-Host "[!] Analyzing Hash: $In..." -ForegroundColor Cyan
        
        $BdeDataBlank = @{ Location = "N/A"; BDE = "N/A"; MACOM = "N/A" }
        $ElasticRule = "None Provided"
        $SrcNsResult = "N/A (Indicator is a Hash)"
        
        $VtH = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/files/$In" -Headers @{ "x-apikey" = $VT_Key }
        $VTHash = "Not Found"
        if ($VtH) { $VTHash = "$($VtH.data.attributes.last_analysis_stats.malicious) Detections" }
        
        $Ctx = "Hash:$In, VT:$VTHash"
        
        $AnalyzeLoop = $true
        do {
            $AI = Invoke-AIAnalysis -ContextData $Ctx -ElasticRule $ElasticRule
            Write-Ticket -Type "Hash" -Indicator $In -NetName "N/A" -Country "N/A" -Descr "N/A" -VT $VTHash -Abuse "N/A" -ISP "N/A" -Link "N/A" -AI $AI -ArinH "N/A" -BdeData $BdeDataBlank -Protocol "N/A" -SrcNsResult $SrcNsResult
            
            Write-Host "`n[?] Post-Ticket Actions:" -ForegroundColor Yellow
            Write-Host "[r] Re-run AI Analysis"
            Write-Host "[c] Start Interactive AI Chat"
            Write-Host "[Enter] Analyze a new indicator"
            $PostAction = Read-Host -Prompt "Action"
            
            if ($PostAction -eq 'r') { Write-Host "`n[!] Re-running..." -ForegroundColor Cyan }
            elseif ($PostAction -eq 'c') { Start-AIChat -Context $Ctx -Verdict $AI -ElasticRule $ElasticRule; $AnalyzeLoop = $false }
            else { $AnalyzeLoop = $false }
        } while ($AnalyzeLoop -eq $true)
    }
    else { Write-Host "[ERROR] Unrecognized indicator format." -ForegroundColor Red }
}
