# --- CORE API WRAPPER & HELPER FUNCTIONS ---
function Invoke-SafeRest {
    param($Uri, $Headers, $Method = 'Get', $Body)
    try {
        $params = @{ Uri = $Uri; Method = $Method; TimeoutSec = 25 }
        if ($Headers) { $params.Headers = $Headers }
        if ($Body) { $params.Body = $Body }
        return Invoke-RestMethod @params
    } catch { return $null }
}

function Get-BdeInfo {
    param([string]$SearchLocation)
    $Result = @{ Location = $SearchLocation; BDE = "(Check manual list)"; MACOM = "(Check manual list)"; AORStatus = "OUT OF AOR (Not in Master List)" }
    
    if ([string]::IsNullOrWhiteSpace($SearchLocation) -or $SearchLocation -eq "N/A") { 
        $Result.Location = "(Check https://www.nic.mil/cgi-bin/whoisweb)"
        $Result.AORStatus = "UNKNOWN"
        return $Result 
    }
    
    foreach ($Row in $Global:BdeMasterList) {
        if ($Row.Location -match [regex]::Escape($SearchLocation) -or $SearchLocation -match [regex]::Escape($Row.Location)) {
            $Result.Location = $Row.Location 
            $Result.BDE = $Row.BDE
            $Result.MACOM = $Row.MACOM
            $Result.AORStatus = $Row.AORStatus
            break
        }
    }
    return $Result
}

# HELPER: Modular NSLookup
function Get-NsLookup {
    param($Target)
    if ([string]::IsNullOrWhiteSpace($Target) -or $Target -eq "N/A") { return "N/A" }
    
    $NsRaw = cmd.exe /c "nslookup $Target 2>&1" | Out-String
    if ($NsRaw -match "Non-existent domain|can't find|NXDOMAIN|\*\*\*") {
        return "Non-existent domain"
    } elseif ([string]::IsNullOrWhiteSpace($NsRaw)) {
        return "Non-existent domain"
    } elseif ($NsRaw -match "(?im)^Name:\s+(.+)") {
        return $Matches[1].Trim()
    } else {
        return $NsRaw.Trim()
    }
}

# HELPER: Modular ARIN RDAP with Variance Handling
function Get-RdapInfo {
    param($IP)
    $Result = @{ NetRange = "N/A"; NetName = "N/A"; Type = "N/A"; Country = "N/A" }
    if ([string]::IsNullOrWhiteSpace($IP) -or $IP -eq "N/A") { return $Result }
    Write-Host "[!] Querying ARIN RDAP for $IP..." -ForegroundColor Cyan
    $RdapRes = Invoke-SafeRest -Uri "https://rdap.arin.net/registry/ip/$IP" -Headers @{ "Accept" = "application/rdap+json" }
    
    if ($RdapRes) {
        # Handle Variance: NetRange / inetnum / startAddress
        if ($RdapRes.handle) { $Result.NetRange = $RdapRes.handle }
        elseif ($RdapRes.startAddress -and $RdapRes.endAddress) { $Result.NetRange = "$($RdapRes.startAddress) - $($RdapRes.endAddress)" }
        elseif ($RdapRes.inetnum) { $Result.NetRange = $RdapRes.inetnum }
        
        # Handle Name and Type
        if ($RdapRes.name) { $Result.NetName = $RdapRes.name }
        if ($RdapRes.type) { $Result.Type = $RdapRes.type }
        if ($RdapRes.country) { $Result.Country = $RdapRes.country }
    }
    return $Result
}

# --- GENAI ANALYSIS ---
function Invoke-AIAnalysis {
    param($ContextData, $ElasticRule)
    Write-Host "[i] Requesting AI Intelligence Analysis..." -ForegroundColor Magenta
    $Headers = @{ "Authorization" = "Bearer $GenAI_Key"; "Content-Type" = "application/json" }
    $Prompt = "Expert cyber incident handling analysis. Plain text only!!! Avoid usage of unintelligible non-English ascii-style formatting where not commanded in this prompt. Do not use emojis. Do not use HTML/CSS formatting to bold/italics/list or order, etc as it will not work in plaintext. If producing a URL, file hash, or filepath from a potentially malicious payload, obfuscate or defang the URL by placing brackets around the colons, and replace 'https' with 'hxxps' by whatever means necessary to prevent it from highlighting as an embedded URL or hyperlink, to prevent accidental clicking. DO NOT defang or obfuscate IPs. When writing in the 'CSSP Analysis' section, write only your analysis; no extra formatting such as hyphens, linebreaks, etcetera are required, and no title is required as your prompt is pre-formatted to inject into a Powershell script outside of Gemini. Be detailed yet concise. Analyze the provided telemetry based on the information gathered via open source intelligence using the embedded API keys. The alert triggered on this Elastic Rule: '$ElasticRule'. 1 paragraph summary assessing the relationship between these indicators and the rule. DO NOT SAY ANYTHING ALONG THE LINES OF 'I, Gemini Enterprise, have analyzed the network telemetry involving source IP 3.5.12.238 and target IP 65.116.218.113.' Do not acknowledge yourself in your analysis. Do not write any suggestions or recommendations; write only the facts that have been observed with open source material." + $ContextData
    $Payload = @{ model = $GenAI_Model; messages = @(@{ role = "user"; content = $Prompt }) } | ConvertTo-Json -Depth 10
    $Response = Invoke-SafeRest -Uri $GenAI_Endpoint -Method Post -Headers $Headers -Body $Payload
    if ($Response) { return $Response.choices[0].message.content.Trim() }
    return "AI Analysis failed to generate a response. Resend another request as this may have been a parsing issue. If this occurs multiple times and is not due to network access or admin restrictions, check that the GenAI API key in this code is unlocked or active as the key may have expired. Go to https://genai.mil/stark/user-ui/ for new API keys. If the key does not belong to you, generate a personal API key at the URL and add it to line 15 in this repository. Other portions of this repository may need to be updated (especially API keys) if the code continues to fail at total execution."
}

# --- INTERACTIVE CHAT SESSION ---
function Start-AIChat {
    param($Context, $Verdict, $ElasticRule)
    Write-Host "`n--- AI CHAT MODE ACTIVATED ---" -ForegroundColor Magenta
    Write-Host "Type 'done' to exit.`n" -ForegroundColor Gray
    $History = @(); $History += @{ role = "system"; content = "Expert cyber incident handling analysis. Rule: $ElasticRule. Context: $Context. Verdict: $Verdict" }
    while ($true) {
        $In = Read-Host -Prompt "[YOU]"
        if ($In -eq 'done' -or $In -eq 'exit') { break }
        $History += @{ role = "user"; content = $In }
        $Payload = @{ model = $GenAI_Model; messages = $History } | ConvertTo-Json -Depth 10
        $Res = Invoke-SafeRest -Uri $GenAI_Endpoint -Method Post -Headers @{ "Authorization" = "Bearer $GenAI_Key"; "Content-Type" = "application/json" } -Body $Payload
        if ($Res) { $Ans = $Res.choices.message.content.Trim(); Write-Host "[AI] $Ans`n" -ForegroundColor Cyan; $History += @{ role = "assistant"; content = $Ans } }
    }
}

# --- TICKET GENERATOR ---
function Write-Ticket {
    param($Type, $Indicator, $NetName, $Country, $StateProv, $VT, $Abuse, $ISP, $Link, $BdeData, $AI = "", $Descr = "N/A", $ArinH, $ArinT, $MilIP = "N/A", $MilPort = "N/A", $MilNsResult = "N/A", $MilArinH = "N/A", $MilArinN = "N/A", $MilDescr = "N/A", $MilCountry = "N/A", $MilStateProv = "N/A", $MilLink = "N/A")
    
    $DomFor = "N/A"
    if ($Country -eq "US") { $DomFor = "Domestic" } elseif ($Country -ne "N/A") { $DomFor = "Foreign" }
    
    # Get Source NSLookup
    $SrcNsResult = "N/A (Indicator is a Hash)"
    if ($Type -in @("IP", "URL")) { $SrcNsResult = Get-NsLookup -Target $Indicator }

    $MilLink = "N/A"; if ($MilIP -ne "N/A") { $MilLink = "https://www.whois.com/whois/$MilIP" }
    
    $T =  "- AFFECTED LOCATION: $($BdeData.Location)`n"
    $T += "- AOR STATUS: $($BdeData.AORStatus)`n"
    $T += "- BDE: $($BdeData.BDE)`n- MACOM: $($BdeData.MACOM)`n- COCOM: NORTHCOM`n- EVENT TIME: (Check Elastic '@timestamp')`n- DIRECTION: Inbound`n- SENSOR: (Check Elastic 'observer.name')`n- PROTOCOL: (Check Elastic)`n"
    $T += "************************************************************`n"
    $T += "PAYLOAD: (Check Elastic for 'http.request.body.content')`n"
    $T += "************************************************************`n"
    $T += "- KIBANA EVENT GRID [X] HITS WITHIN 4 HRS`n"
    $T += "************************************************************`n"
    $T += "Source IP Foreign or Domestic: $DomFor`n`n"
    $T += "- Source IP: $Indicator ($Type)`n- Source Port: `n- NSLOOKUP: $SrcNsResult`n`n"
    
    $T += "--- SOURCE ARIN ---`n"
    $T += "NetRange:    $ArinH`nNetName:    $NetName`nDescr:    $Descr`nCountry:    $Country`nState/Prov:    $StateProv`n"
    $T += "WHOIS LINK: $Link`n`n"
    
    $T += "- THREAT INTEL:`n"
    $T += "VirusTotal: $VT`nAbuseIPDB Score: $Abuse`nAbuseIPDB ISP:  $ISP`n"
    $T += "************************************************************`n"
    $T += "MIL IP Foreign or domestic: Domestic`n`n"
    $T += "MIL Destination`n- Destination IP: $MilIP`n- Destination Port: $MilPort`n- NSLOOKUP: $MilNsResult`n`n"
    
    $T += "--- DESTINATION (MIL) ARIN ---`n"
    $T += "NetRange:    $MilArinH`nNetName:    $MilArinN`nDescr:    $MilDescr`nCountry:    $MilCountry`nState/Prov:    $MilStateProv`n"
    $T += "WHOIS LINK: $MilLink`n"
    $T += "************************************************************`n"
    $T += "- MDE:`n"
    $T += "************************************************************`n"
    $T += "- CSSP ANALYSIS:`n`n$AI`n`nDespite the action being blocked by an IPS, there are currently no IP-Blocks submitted at the network / IP level. CSSP is submitting a 30-day IP-Block request as an additional countermeasure."
    
    # 1. Send plain text to clipboard (so the ticketing system gets clean text)
    $T | Set-Clipboard
    
    # 2. Print to console with N/A highlighted in Red
    $T_Lines = $T -split "`n"
    foreach ($Line in $T_Lines) {
        if ($Line -match "N/A") {
            $Parts = $Line -split "N/A"
            for ($i = 0; $i -lt $Parts.Count; $i++) {
                Write-Host $Parts[$i] -NoNewline -ForegroundColor Green
                if ($i -lt ($Parts.Count - 1)) {
                    Write-Host "N/A" -NoNewline -ForegroundColor Red
                }
            }
            Write-Host "" # Newline after the line finishes
        } else {
            Write-Host $Line -ForegroundColor Green
        }
    }
    
    Write-Host "`n[SUCCESS] Exact Layout Ticket copied to clipboard." -ForegroundColor Cyan
}

# --- MAIN LOOP ---
while ($true) {
    Write-Host "`n==================================================" -ForegroundColor Red
    Write-Host "   CYBER THREAT INTELLIGENCE CO-PILOT v8.2.0" -ForegroundColor Blue
    Write-Host "==================================================" -ForegroundColor Red
    $In = Read-Host -Prompt "`nEnter Indicator (Source IP, URL, Hash) or 'Exit'"
    if ($In -eq 'Exit' -or $In -eq 'exit') { break }
    $In = $In.Trim()
    
    if ($In -match "^(\d{1,3}\.){3}\d{1,3}$") { 
        # IP ROUTE
        Write-Host "[!] Analyzing IP: $In..." -ForegroundColor Cyan
        
        # 1. Prompt for Destination IP
        $MilIP = Read-Host -Prompt "Enter MIL Destination IP (or press Enter to skip)"
        $MilIP = $MilIP.Trim()

        # 2. Prompt for Elastic IPS trigger
        $ElasticRule = Read-Host -Prompt "Enter Elastic observer.rule.name (or press Enter to skip)"
        if ([string]::IsNullOrWhiteSpace($ElasticRule)) { $ElasticRule = "None Provided" }
        
        # 3. Source IP Threat Intel
        $AbRes = Invoke-SafeRest -Uri "https://api.abuseipdb.com/api/v2/check?ipAddress=$In&maxAgeInDays=90" -Headers @{ "Key" = $Abuse_Key; "Accept" = "application/json" }
        $Ab = "N/A"; $ISP = "N/A"; $Cty = "N/A"
        if ($AbRes) { $Ab = "$($AbRes.data.abuseConfidenceScore)%"; $ISP = $AbRes.data.isp; $Cty = $AbRes.data.countryCode }
        
        $Vt = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/ip_addresses/$In" -Headers @{ "x-apikey" = $VT_Key }
        $VTRes = "API Error"; $Owner = "N/A"
        if ($Vt) { $VTRes = "$($Vt.data.attributes.last_analysis_stats.malicious) Detections"; $Owner = $Vt.data.attributes.as_owner }
        
        # 4. Prompt for affected Army installation location.
        $InputLocation = (Read-Host -Prompt "Enter Affected Location/Base (e.g. 'Liberty')").Trim()
        $BdeData = Get-BdeInfo -SearchLocation $InputLocation

        # 5. Get RDAP data for Source using the Helper Function
        $SrcArin = Get-RdapInfo -IP $In
        
        # 6. Get RDAP and NSLookup data for MIL Destination using Helper Functions
        $MilNsResult = "N/A"
        $MilLink = "N/A"
        $MilArin = @{ NetRange = "N/A"; NetName = "N/A"; Type = "N/A"; Country = "N/A" }
        
        if ($MilIP -match "^(\d{1,3}\.){3}\d{1,3}$") {
            $MilNsResult = Get-NsLookup -Target $MilIP
            $MilArin = Get-RdapInfo -IP $MilIP
            $MilLink = "https://www.whois.com/whois/$MilIP"
        }
        
        $Net = $ISP; if ($Owner -ne "N/A") { $Net = $Owner }
        $Ctx = "IP:$In, Net:$Net, Abuse:$Ab, VT:$VTRes"
        if ($MilIP -ne "") { $Ctx += ", TargetIP:$MilIP" }
        
        $AI = Invoke-AIAnalysis -ContextData $Ctx -ElasticRule $ElasticRule
        
        # 7. Push everything to Write-Ticket
        Write-Ticket -Type "IP" -Indicator $In -NetName $SrcArin.NetName -Country $Cty -StateProv "N/A" -VT $VTRes -Abuse $Ab -ISP $ISP -Link "https://www.whois.com/whois/$In" -AI $AI -ArinH $SrcArin.NetRange -ArinT $SrcArin.Type `
                     -MilIP $MilIP -MilNsResult $MilNsResult -MilArinH $MilArin.NetRange -MilArinN $MilArin.NetName -MilCountry $MilArin.Country -MilLink $MilLink -BdeData $BdeData -ElasticRule $ElasticRule
        if ((Read-Host -Prompt "Follow-up questions? (y/n)") -eq 'y') { Start-AIChat -Context $Ctx -Verdict $AI -ElasticRule $ElasticRule}
    }
    elseif ($In -like "*.*" -and $In -notmatch "^([a-fA-F0-9]{64}|[a-fA-F0-9]{32})$") {
        # URL ROUTE
        $Domain = $In.Replace("https://","").Replace("http://","").Split("/")[0]
        Write-Host "[!] Analyzing URL/Domain: $In..." -ForegroundColor Cyan
        
        $UsReq = Invoke-SafeRest -Uri "https://urlscan.io/api/v1/scan/" -Method Post -Headers @{ 'API-Key' = $UrlScan_Key; 'Content-Type' = 'application/json' } -Body (@{ url = $In; visibility = "public" } | ConvertTo-Json)
        $UsVal = "Wait for Report"
        if ($UsReq) { Start-Sleep -Seconds 20; $UsRes = Invoke-SafeRest -Uri "https://urlscan.io/api/v1/result/$($UsReq.uuid)/"; if ($UsRes) { $UsVal = "Clean"; if ($UsRes.verdicts.overall.malicious) { $UsVal = "Malicious" } } }
        
        $Vt = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/urls" -Method Post -Headers @{ "x-apikey" = $VT_Key } -Body (@{ url = $In } | ConvertTo-Json)
        $VTRes = "API Error"
        if ($Vt) { Start-Sleep -Seconds 15; $VtR = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/urls/$($Vt.data.id.Split('-')[1])" -Headers @{ "x-apikey" = $VT_Key }; if ($VtR) { $VTRes = "$($VtR.data.attributes.last_analysis_stats.malicious) Detections" } }
        
        $Ctx = "URL:$In, Domain:$Domain, URLScan:$UsVal, VT:$VTRes"
        $AI = Invoke-AIAnalysis -ContextData $Ctx -ElasticRule $ElasticRule
        
        Write-Ticket -Type "URL" -Indicator $In -NetName $Domain -Country "N/A" -VT $VTRes -Abuse $UsVal -ISP "URLScan" -Link "https://www.whois.com/whois/$Domain" -AI $AI -ElasticRule $ElasticRule
        if ((Read-Host -Prompt "Follow-up questions? (y/n)") -eq 'y') { Start-AIChat -Context $Ctx -Verdict $AI -ElasticRule $ElasticRule}
    }
    elseif ($In -match "^([a-fA-F0-9]{64}|[a-fA-F0-9]{32})$") {
        # HASH ROUTE
        Write-Host "[!] Analyzing Hash: $In..." -ForegroundColor Cyan
        $VtH = Invoke-SafeRest -Uri "https://www.virustotal.com/api/v3/files/$In" -Headers @{ "x-apikey" = $VT_Key }
        $VTHash = "Not Found"
        if ($VtH) { $VTHash = "$($VtH.data.attributes.last_analysis_stats.malicious) Detections" }
        
        $Ctx = "Hash:$In, VT:$VTHash"
        $AI = Invoke-AIAnalysis -ContextData $Ctx
        
        Write-Ticket -CombinedWhois $CombinedWhois -CombinedIntel $CombinedIntel -AI $AI -DomForGlobal $DomForGlobal -MilIP $MilIP -MilNsResult $MilNsResult -MilArin $MilArin -BdeData $BdeData
        if ((Read-Host -Prompt "`nFollow-up? (y/n)") -eq 'y') { Start-AIChat -Context $JoinedContext -Verdict $AI -ElasticRule $ElasticRule }
    }
    else { Write-Host "[ERROR] Unrecognized indicator format." -ForegroundColor Red }
}
